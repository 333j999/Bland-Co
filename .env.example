# Copy to .env.local for local work, and set the same keys in the Vercel project.
# NEVER commit real values — this repo is public. .env* is gitignored (except this file).

# ── Admin auth (Vercel) ──
# A long random string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# The admin login password.
ADMIN_PASSWORD=

# ── Convex database ──
# Your deployment URL, printed by `npx convex dev` (looks like https://xxxx.convex.cloud)
CONVEX_URL=
# Shared secret the Vercel API uses to call Convex. Must equal BACKEND_SECRET on Convex.
# Set on Convex with: npx convex env set BACKEND_SECRET <same-value>
CONVEX_BACKEND_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=
RESEND_FROM=Bland & Co <onboarding@resend.dev>

# ── Image/video uploads (Cloudinary) ──
CLOUDINARY_CLOUD_NAME=
# Preferred: signed mode (the secret stays server-side, never reaches the browser)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional fallback: unsigned upload preset (used only if no API secret is set)
CLOUDINARY_UPLOAD_PRESET=
